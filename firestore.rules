rules_version = '2';

// ── Firestore Rules ──────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    match /hall_of_fame/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /fest_clusters/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /fest_events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /fest_info/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // JUYF (Internal College Fest)
    match /juyf_events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /juyf_info/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Anyone can submit an application; only admin can read/delete
    match /recruitment_apps/{docId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // Recruitment dropdown options (managed by admin)
    match /recruitment_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Feedback — anyone can submit, only admin can read/delete
    match /feedback/{docId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    match /results/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
